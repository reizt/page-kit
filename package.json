{
  "name": "page-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:browser": "RUN_BROWSER_TESTS=1 vitest run test/browser.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.29",
    "jsdom": "^26.1.0",
    "playwright": "^1.61.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.10.13",
    "@types/turndown": "^5.0.5",
    "tsx": "^4.21.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
